
<?xml version="1.0"?>
<CLBConfig version="2.0" output="output/">
<!-- 
	Model:	d2q9_pf_velocity 
		Can also be run with d2q9_pf_velocity_CM if the collision type is changed.

	This is the test case from Yos et al. (2019) - Journal of Computational Physics
	Density ratio:10
	Viscosity ratio: 6.324555
	Eotvos number = 100
	Reynolds = 10
	t* = 3750

   Created: 	14-08-2017 
    By:		T.Mitchell
-->
<Geometry nx="288" ny="288" >
	<MRT><Box /></MRT>
	<Wall mask="ALL">
	    <Box   ny="1"  />
	    <Box   dy="-1" />
	</Wall> 
	<ENorth name="ENorth">
	    <Box   dy="-1"  />
	</ENorth>
	<ESouth name="ESouth">
	    <Box   ny="1"  />
	</ESouth>
</Geometry>
<Model>
	<Param name="PHI_E" value="0" />
	<Param name="PHI_E" value="30" zone="ENorth"/>
	<Param name="PHI_E" value="0" zone="ESouth"/>

	<Param name="Density_h" value="1" />    
	<Param name="Density_l" value="1" />    

	<Param name="Viscosity_h" value="0.1" />    
	<Param name="Viscosity_l" value="0.1" />    

	<Param name="PhaseField_h" value="1" />    
	<Param name="PhaseField_l" value="0" />    
	<Param name="PhaseField_init"   value="1" />    

	<Param name="Radius"   value="47" />
	<Param name="CenterX"  value="144" />
	<Param name="CenterY"  value="144" />
	<Param name="BubbleType"  value="1" />

	<Param name="M"     value="0.05" />   
	<Param name="W"     value="4.7" /> 
	<Param name="sigma" value="0.001" />

</Model>
<Init/>
<VTK/>
<VTK Iterations="2"/>
<RunAction name="Iter_Electric" Iterations="10" />
<!--<SolveWithConvergence 	action="Iteration"
						converge_action="Iter_Electric" 
						global="ElectricChange" 
						threshold="1e-06" 
						min_iterations="1000"
						max_stage_iterations="10000"
						iterations="20"/>-->
</CLBConfig>
